        "sendTo": "={{ $('Prepare Email Data').first().json.vendor_email }}",
        "subject": "=✅ Payment Confirmation — {{ $('Prepare Email Data').first().json.vendor_name }} | Invoice {{ $('Prepare Email Data').first().json.invoice_number }}",
        "message": "=<div style=\"font-family:Arial,sans-serif;max-width:620px;margin:0 auto;color:#333;border:1px solid #e2e8f0;border-radius:8px;overflow:hidden\">\n  <div style=\"background:#0f0f1a;padding:28px 32px;text-align:center\">\n    <h1 style=\"color:#ffffff;margin:0;font-size:26px;letter-spacing:4px;font-weight:800;text-transform:uppercase\">MIRAGGIO</h1>\n    <p style=\"color:#6b7280;margin:6px 0 0;font-size:11px;letter-spacing:2px;text-transform:uppercase\">Lifestyles Private Limited</p>\n  </div>\n  <div style=\"background:#f0fdf4;padding:20px 32px;border-bottom:1px solid #bbf7d0\">\n    <table style=\"width:100%\"><tr>\n      <td style=\"vertical-align:middle;padding-right:12px;font-size:28px;width:40px\">✅</td>\n      <td style=\"vertical-align:middle\">\n        <h2 style=\"color:#15803d;margin:0;font-size:18px;font-weight:700\">Payment Successfully Processed</h2>\n        <p style=\"color:#16a34a;margin:4px 0 0;font-size:13px\">Dear {{ $('Prepare Email Data').first().json.vendor_name }}, your invoice payment has been completed.</p>\n      </td>\n    </tr></table>\n  </div>\n  <div style=\"padding:28px 32px\">\n    <h3 style=\"margin:0 0 16px;font-size:12px;color:#6b7280;text-transform:uppercase;letter-spacing:1.5px;font-weight:700;border-bottom:2px solid #f1f5f9;padding-bottom:10px\">Payment Details</h3>\n    <table style=\"width:100%;border-collapse:collapse;font-size:14px\">\n      <tr style=\"border-bottom:1px solid #f8f9fa\">\n        <td style=\"padding:11px 12px;background:#f9fafb;font-weight:600;color:#374151;width:44%\">Invoice Number</td>\n        <td style=\"padding:11px 12px;font-weight:700;color:#0f0f1a\">{{ $('Prepare Email Data').first().json.invoice_number }}</td>\n      </tr>\n      <tr style=\"border-bottom:1px solid #f8f9fa\">\n        <td style=\"padding:11px 12px;background:#f9fafb;font-weight:600;color:#374151\">Amount Paid</td>\n        <td style=\"padding:11px 12px;font-weight:800;color:#15803d;font-size:18px\">{{ $('Prepare Email Data').first().json.amount_formatted }}</td>\n      </tr>\n      <tr style=\"border-bottom:1px solid #f8f9fa\">\n        <td style=\"padding:11px 12px;background:#f9fafb;font-weight:600;color:#374151\">Payment Mode</td>\n        <td style=\"padding:11px 12px\">{{ $('Prepare Email Data').first().json.payment_mode }}</td>\n      </tr>\n      <tr style=\"border-bottom:1px solid #f8f9fa\">\n        <td style=\"padding:11px 12px;background:#f9fafb;font-weight:600;color:#374151\">UTR / Reference No.</td>\n        <td style=\"padding:11px 12px;font-family:'Courier New',monospace;font-size:13px;font-weight:700;color:#1e40af\">{{ $('Prepare Email Data').first().json.utr }}</td>\n      </tr>\n      <tr style=\"border-bottom:1px solid #f8f9fa\">\n        <td style=\"padding:11px 12px;background:#f9fafb;font-weight:600;color:#374151\">Payment Date</td>\n        <td style=\"padding:11px 12px\">{{ $('Prepare Email Data').first().json.paid_at }}</td>\n      </tr>\n      <tr style=\"border-bottom:1px solid #f8f9fa\">\n        <td style=\"padding:11px 12px;background:#f9fafb;font-weight:600;color:#374151\">Billing Period</td>\n        <td style=\"padding:11px 12px;font-size:13px;color:#6b7280\">{{ $('Prepare Email Data').first().json.billing_period_start }} → {{ $('Prepare Email Data').first().json.billing_period_end }}</td>\n      </tr>\n      <tr>\n        <td style=\"padding:11px 12px;background:#f9fafb;font-weight:600;color:#374151\">Authorised By</td>\n        <td style=\"padding:11px 12px\">{{ $('Prepare Email Data').first().json.paid_by }}</td>\n      </tr>\n    </table>\n  </div>\n  <div style=\"padding:0 32px 28px\">\n    <div style=\"background:#fffbeb;border-left:4px solid #f59e0b;padding:14px 16px;border-radius:0 6px 6px 0\">\n      <p style=\"margin:0;font-size:13px;color:#92400e\"><strong>📎 Payment receipt is attached</strong> to this email for your records.</p>\n    </div>\n  </div>\n  <div style=\"background:#f8fafc;padding:20px 32px;border-top:1px solid #e2e8f0;text-align:center\">\n    <p style=\"color:#9ca3af;font-size:11px;margin:0;line-height:2\">Automated confirmation from <strong>Miraggio Lifestyles Private Limited</strong><br>Queries: <a href=\"mailto:accounts@miraggiolife.com\" style=\"color:#0f0f1a;font-weight:600\">accounts@miraggiolife.com</a></p>\n  </div>\n</div>",
