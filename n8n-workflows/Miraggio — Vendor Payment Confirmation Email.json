      "id": "c3d4e5f6-a7b8-9012-cdef-123456789012",
      "name": "Fetch Bill + Vendor",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [-20, 0]
    },
    {
      "parameters": {
        "jsCode": "const payment = $('Extract Payment Data').first().json;\nconst bill    = $input.first()?.json ?? {};\nconst vendor  = bill.vendors ?? {};\n\nconst formatAmount = (n) =>\n  '₹' + new Intl.NumberFormat('en-IN', { maximumFractionDigits: 2, minimumFractionDigits: 2 }).format(Number(n) || 0);\n\nconst formatDate = (d) => {\n  if (!d) return '—';\n  try { return new Date(d).toLocaleDateString('en-IN', { day: '2-digit', month: 'long', year: 'numeric' }); }\n  catch { return d; }\n};\n\nconst modeLabels = {\n  NEFT:'NEFT (National Electronic Funds Transfer)',\n  RTGS:'RTGS (Real-Time Gross Settlement)',\n  IMPS:'IMPS (Immediate Payment Service)',\n  UPI:'UPI', CHEQUE:'Cheque', CASH:'Cash', DD:'Demand Draft'\n};\nconst rawMode  = (payment.payment_mode ?? '').toUpperCase();\nconst modeLabel = modeLabels[rawMode] ?? payment.payment_mode ?? '—';\n\n// Clean filename: INV-001_payment-id.pdf\nconst invoiceNum  = (bill.invoice_number ?? 'NOINV').replace(/[^a-zA-Z0-9-_]/g, '-');\nconst paymentId   = (payment.payment_id ?? 'noid').slice(0, 8);\nconst storagePath = `confirmed/${invoiceNum}_${paymentId}.pdf`;\nconst publicUrl   = `https://ydoitzgqavfmbyrirxxe.supabase.co/storage/v1/object/public/receipts/${storagePath}`;\n\nreturn [{\n  json: {\n    payment_id:       payment.payment_id,\n    bill_id:          payment.bill_id,\n    vendor_id:        payment.vendor_id,\n    payment_mode:     modeLabel,\n    utr:              payment.utr_or_cheque_number ?? '—',\n    amount_formatted: formatAmount(payment.amount_paid ?? bill.amount ?? 0),\n    paid_at:          formatDate(payment.paid_at),\n    paid_by:          payment.paid_by ?? '—',\n    receipt_url:      payment.receipt_url ?? null,\n    receipt_filename: payment.receipt_filename ?? 'payment_receipt.pdf',\n    // Storage destination\n    storage_path:     storagePath,\n    storage_public_url: publicUrl,\n    // Bill\n    invoice_number:        bill.invoice_number ?? '—',\n    billing_period_start:  formatDate(bill.billing_period_start),\n    billing_period_end:    formatDate(bill.billing_period_end),\n    // Vendor\n    vendor_name:    vendor.name ?? 'Vendor',\n    vendor_email:   vendor.email ?? '',\n    vendor_gstin:   vendor.gstin ?? '—',\n    vendor_contact: vendor.contact_person ?? '—',\n  }\n}];"
      },
