    {
      "parameters": {
        "jsCode": "// Supabase DB Webhook posts { body: { type, table, record } }\nconst record = $input.first().json.body?.record ?? $input.first().json.record ?? $input.first().json;\n\nconst formatAmount = (n) =>\n  '₹' + new Intl.NumberFormat('en-IN', { maximumFractionDigits: 2, minimumFractionDigits: 2 }).format(Number(n) || 0);\n\nconst formatDate = (d) => {\n  if (!d) return '—';\n  try { return new Date(d).toLocaleDateString('en-IN', { day: '2-digit', month: 'long', year: 'numeric' }); }\n  catch { return d; }\n};\n\nconst modeLabels = {\n  NEFT: 'NEFT (National Electronic Funds Transfer)',\n  RTGS: 'RTGS (Real-Time Gross Settlement)',\n  IMPS: 'IMPS (Immediate Payment Service)',\n  UPI: 'UPI', CHEQUE: 'Cheque', CASH: 'Cash', DD: 'Demand Draft'\n};\nconst rawMode  = (record.payment_mode ?? '').toUpperCase();\nconst modeLabel = modeLabels[rawMode] ?? record.payment_mode ?? '—';\n\nreturn [{\n  json: {\n    notification_id:      record.id,\n    payment_id:           record.payment_id,\n    vendor_email:         record.vendor_email ?? '',\n    vendor_name:          record.vendor_name  ?? 'Vendor',\n    invoice_number:       record.invoice_number ?? '—',\n    amount_formatted:     formatAmount(record.amount_paid ?? 0),\n    payment_mode:         modeLabel,\n    utr:                  record.utr ?? '—',\n    paid_at:              formatDate(record.paid_at),\n    paid_by:              record.paid_by ?? '—',\n    billing_period_start: formatDate(record.billing_period_start),\n    billing_period_end:   formatDate(record.billing_period_end),\n  }\n}];"
      },
