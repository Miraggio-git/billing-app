      "id": "fbd277c4-8662-4760-96b4-253ba7fb506c",
      "name": "Supabase — Lookup Token",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -672,
        256
      ]
    },
    {
      "parameters": {
        "jsCode": "// Validate token: must exist, not used, not expired.\n// Returns ONE item with { valid, reason, ...flat fields }.\n\nconst rows = $input.first().json;\n\n// Supabase returns an array. Handle both array + raw shapes.\nconst row = Array.isArray(rows) ? rows[0] : rows;\n\nif (!row || !row.token) {\n  return [{ json: { valid: false, reason: 'INVALID_TOKEN', message: 'This approval link is invalid.' } }];\n}\n\nif (row.used === true) {\n  return [{ json: { valid: false, reason: 'ALREADY_USED', message: 'This approval link has already been used.' } }];\n}\n\nconst expiresAt = new Date(row.expires_at);\nif (expiresAt < new Date()) {\n  return [{ json: { valid: false, reason: 'EXPIRED', message: 'This approval link has expired.' } }];\n}\n\nconst bill   = row.bills   || {};\nconst vendor = bill.vendors || {};\n\nreturn [{\n  json: {\n    valid: true,\n    token: row.token,\n    token_id: row.id,\n    bill_id: row.bill_id,\n    level: row.level,           // 'L1' or 'L2'\n    action: row.action,          // 'APPROVE' or 'REJECT'\n    level_action: row.level + '_' + row.action,  // e.g. 'L1_APPROVE'\n\n    // Bill fields\n    invoice_number: bill.invoice_number,\n    amount: bill.amount,\n    bill_status: bill.status,\n    anomaly_flags: bill.anomaly_flags || [],\n\n    // Vendor fields (for emails)\n    vendor_id: vendor.id,\n    vendor_name: vendor.name,\n    vendor_email: vendor.email,\n    vendor_bank_name: vendor.bank_name,\n    vendor_bank_account_no: vendor.bank_account_no,\n    vendor_bank_ifsc: vendor.bank_ifsc,\n    vendor_bank_account_name: vendor.bank_account_name,\n\n    // Bill PDF\n    bill_pdf_url: bill.bill_pdf_url || null,\n\n    // Approver tracking — mapped to known approver emails by level\n    approver_email: row.level === 'L1' ? 'mandeep@miraggiolife.com' : 'Deepak.singh@miraggiolife.com',\n    approved_at: new Date().toISOString(),\n\n    // Vendor category\n    vendor_category: vendor.category || null\n  }\n}];"
      },
