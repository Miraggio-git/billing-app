    {
      "parameters": {
        "jsCode": "function generateToken() {\n  let token = '';\n  const chars = '0123456789abcdef';\n  for (let i = 0; i < 64; i++) {\n    token += chars[Math.floor(Math.random() * 16)];\n  }\n  return token;\n}\n\n// Pull data from the previous Validate Token node\nconst data = $('Validate Token').first().json;\n\n// Hardcoded base URL (Zero $env references to prevent n8n Cloud crashes)\nconst baseUrl = 'https://mirragiohimanshu.app.n8n.cloud/webhook/approval';\n\nconst approveToken = generateToken();\nconst rejectToken  = generateToken();\n\nreturn [{\n  json: {\n    bill_id:                  data.bill_id,\n    approveToken:             approveToken,\n    rejectToken:              rejectToken,\n    approveLink:              `${baseUrl}?token=${approveToken}`,\n    rejectLink:               `${baseUrl}?token=${rejectToken}`,\n    vendor_name:              data.vendor_name,\n    vendor_email:             data.vendor_email,\n    amount:                   data.amount,\n    invoice_number:           data.invoice_number,\n    vendor_bank_name:         data.vendor_bank_name,\n    vendor_bank_account_no:   data.vendor_bank_account_no,\n    vendor_bank_ifsc:         data.vendor_bank_ifsc,\n    vendor_bank_account_name: data.vendor_bank_account_name,\n    bill_pdf_url:             data.bill_pdf_url || null,\n    vendor_category:          data.vendor_category || null\n  }\n}];"
      },
